<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= userData.title || 'Weekly Planner' %> | Leo Apps</title>
  
  <!-- Modern Fonts and Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=block" rel="stylesheet" />

  <style>
    :root {
      --bg-gradient: linear-gradient(135deg, #090d16 0%, #0f172a 40%, #1e1b4b 100%);
      --card-bg: rgba(30, 41, 59, 0.45);
      --card-bg-hover: rgba(30, 41, 59, 0.6);
      --card-border: rgba(255, 255, 255, 0.05);
      --card-border-hover: rgba(255, 255, 255, 0.1);
      
      --accent-primary: #8b5cf6;
      --accent-secondary: #ec4899;
      --accent-gradient: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 50%, #6d28d9 100%);
      --accent-glow: rgba(139, 92, 246, 0.25);
      
      --today-gradient: linear-gradient(135deg, #a78bfa 0%, #f472b6 100%);
      --today-bg: rgba(49, 46, 129, 0.4);
      --today-glow: rgba(167, 139, 250, 0.35);

      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --text-success: #34d399;
      
      --checkbox-bg: rgba(15, 23, 42, 0.6);
      --checkbox-border: rgba(255, 255, 255, 0.15);
      --checkbox-checked-bg: #8b5cf6;
      --checkbox-checked-border: #8b5cf6;
      
      --period-bg-morning: rgba(251, 191, 36, 0.1);
      --period-text-morning: #f59e0b;
      --period-bg-afternoon: rgba(56, 189, 248, 0.1);
      --period-text-afternoon: #38bdf8;
      --period-bg-evening: rgba(129, 140, 248, 0.1);
      --period-text-evening: #818cf8;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg-gradient);
      color: var(--text-main);
      min-height: 100vh;
      padding: 40px 20px;
      overflow-x: hidden;
      line-height: 1.5;
    }

    /* Ambient dynamic glows */
    .glow-container {
      position: fixed;
      width: 100vw;
      height: 100vh;
      top: 0;
      left: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(140px);
      opacity: 0.12;
    }

    .orb-1 {
      width: 500px;
      height: 500px;
      background: #8b5cf6;
      top: -100px;
      right: -100px;
    }

    .orb-2 {
      width: 400px;
      height: 400px;
      background: #ec4899;
      bottom: -100px;
      left: -100px;
    }

    .app-container {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    /* Header */
    header {
      text-align: center;
      margin-bottom: 40px;
      animation: slideDown 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .logo-container {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 60px;
      height: 60px;
      border-radius: 16px;
      background: var(--accent-gradient);
      box-shadow: 0 8px 24px rgba(139, 92, 246, 0.3);
      margin-bottom: 16px;
    }

    .logo-container .material-symbols-outlined {
      font-size: 32px;
      color: #ffffff;
    }

    h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -1px;
      margin-bottom: 8px;
      background: linear-gradient(to right, #ffffff, #cbd5e1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    header p {
      font-size: 16px;
      color: var(--text-muted);
      font-weight: 400;
    }

    /* Floating navigation for current day shortcut */
    .nav-bar {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      margin-bottom: 40px;
      animation: fadeIn 1s ease-out;
    }

    .nav-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: rgba(30, 41, 59, 0.5);
      border: 1px solid var(--card-border);
      border-radius: 30px;
      color: var(--text-main);
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    .nav-link:hover {
      background: var(--accent-gradient);
      border-color: transparent;
      box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
      transform: translateY(-2px);
    }

    .nav-link .material-symbols-outlined {
      font-size: 18px;
    }

    /* Main Board Layout */
    .planner-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 40px;
      align-items: start;
    }

    @media (min-width: 768px) {
      .planner-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .planner-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Day Card styling */
    .day-card {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      padding: 24px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .day-card:hover {
      transform: translateY(-4px) scale(1.01);
      background: var(--card-bg-hover);
      border-color: var(--card-border-hover);
      box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.3);
    }

    /* Special Highlight for Today */
    .today-highlight {
      background: var(--today-bg);
      border: 1.5px solid transparent;
      box-shadow: 0 0 30px var(--today-glow);
    }

    .today-highlight::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--today-gradient);
    }

    .day-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .day-name {
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: #ffffff;
    }

    .today-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      background: var(--today-gradient);
      border-radius: 20px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.5px;
      color: #ffffff;
      text-transform: uppercase;
    }

    /* Period Sections inside Cards */
    .period-section {
      margin-bottom: 18px;
    }

    .period-section:last-child {
      margin-bottom: 0;
    }

    .period-title {
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      padding: 3px 8px;
      border-radius: 6px;
      display: inline-block;
      margin-bottom: 10px;
    }

    .period-Morning {
      background: var(--period-bg-morning);
      color: var(--period-text-morning);
    }

    .period-Afternoon {
      background: var(--period-bg-afternoon);
      color: var(--period-text-afternoon);
    }

    .period-Evening {
      background: var(--period-bg-evening);
      color: var(--period-text-evening);
    }

    /* Activity Items list */
    .activity-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .activity-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px 12px;
      background: rgba(15, 23, 42, 0.25);
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.02);
      transition: all 0.2s ease;
    }

    .activity-item:hover {
      background: rgba(15, 23, 42, 0.4);
      border-color: rgba(255, 255, 255, 0.05);
      transform: translateX(2px);
    }

    /* Custom Checkbox Link Button */
    .checkbox-btn {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border-radius: 6px;
      border: 1.5px solid var(--checkbox-border);
      background: var(--checkbox-bg);
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      margin-top: 2px;
    }

    .checkbox-btn:hover {
      border-color: var(--accent-primary);
      box-shadow: 0 0 8px var(--accent-glow);
    }

    .checkbox-btn .material-symbols-outlined {
      font-size: 16px;
      color: transparent;
      font-weight: bold;
      transition: color 0.2s ease;
    }

    .activity-item.completed .checkbox-btn {
      background: var(--checkbox-checked-bg);
      border-color: var(--checkbox-checked-border);
      box-shadow: 0 0 10px rgba(139, 92, 246, 0.4);
    }

    .activity-item.completed .checkbox-btn .material-symbols-outlined {
      color: #ffffff;
    }

    .activity-content {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .activity-time {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      letter-spacing: 0.3px;
    }

    .activity-text {
      font-size: 13.5px;
      font-weight: 500;
      color: var(--text-main);
      transition: all 0.2s ease;
    }

    .activity-item.completed .activity-text {
      text-decoration: line-through;
      color: var(--text-muted);
      opacity: 0.7;
    }

    /* Goals / Habits Dashboard Card */
    .goals-wrapper {
      margin-top: 32px;
      animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .goals-card {
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.6) 0%, rgba(15, 23, 42, 0.8) 100%);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 30px;
      box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.4);
    }

    .goals-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .goals-header .material-symbols-outlined {
      color: var(--accent-secondary);
      font-size: 28px;
    }

    .goals-title {
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: #ffffff;
    }

    .goals-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    @media (min-width: 768px) {
      .goals-list {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .goal-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: rgba(255, 255, 255, 0.03);
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.02);
      transition: all 0.3s ease;
    }

    .goal-item:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
    }

    .goal-item .material-symbols-outlined {
      color: var(--accent-secondary);
      font-size: 20px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .goal-text {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-main);
    }

    /* Keyframes Animations */
    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  </style>
</head>
<body>
  
  <!-- Background Ambient Glows -->
  <div class="glow-container">
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
  </div>

  <div class="app-container">
    
    <!-- Top Header -->
    <header>
      <div class="logo-container">
        <span class="material-symbols-outlined">calendar_today</span>
      </div>
      <h1><%= userData.title || 'WEEKLY PLANNER' %></h1>
      <p><%= userData.subtitle || 'Daily Checklist' %></p>
    </header>

    <% 
    let hasToday = false;
    schedule.forEach(function(day) {
        if (day.dayName.toLowerCase() === currentDayName.toLowerCase()) {
            hasToday = true;
        }
    });
    %>
    <!-- Navigation Bar -->
    <div class="nav-bar">
      <% if (hasToday) { %>
        <a href="#today" class="nav-link">
          <span class="material-symbols-outlined">today</span>
          Jump to Today (<%= currentDayName %>)
        </a>
      <% } %>
      <a href="/aac/legacy/<%= userId %>/edit" class="nav-link">
        <span class="material-symbols-outlined">edit</span>
        Edit Planner
      </a>
    </div>

    <!-- Weekly Board Grid -->
    <main class="planner-grid">
      <% schedule.forEach(function(day) { %>
        <% 
        const isToday = day.dayName.toLowerCase() === currentDayName.toLowerCase();
        const dayCardClass = isToday ? 'day-card today-highlight' : 'day-card';
        const todayAnchor = isToday ? 'id="today"' : `id="${day.id}"`;
        %>
        
        <div class="<%= dayCardClass %>" <%= todayAnchor %>>
          <div class="day-header">
            <span class="day-name"><%= day.dayName %></span>
            <% if (isToday) { %>
              <span class="today-badge">Today</span>
            <% } %>
          </div>

          <!-- Group Activities by Period -->
          <% 
          const periods = ['Morning', 'Afternoon', 'Evening'];
          periods.forEach(function(period) {
              const periodActs = (day.activities || [])
                  .filter(a => a.period === period)
                  .sort((a, b) => (a.order || 0) - (b.order || 0));
              
              if (periodActs.length > 0) {
          %>
                <div class="period-section">
                  <div class="period-title period-<%= period %>"><%= period %></div>
                  <div class="activity-list">
                    <% periodActs.forEach(function(act) { %>
                      <% 
                      const isCompleted = !!act.completed;
                      const nextState = !isCompleted;
                      const toggleUrl = `/aac/legacy/${userId}/toggle?day=${day.id}&itemId=${encodeURIComponent(act.id)}&completed=${nextState}&tz=${encodeURIComponent(timezone)}`;
                      %>
                      <div class="activity-item <%= isCompleted ? 'completed' : '' %>">
                        <a href="<%= toggleUrl %>" class="checkbox-btn">
                          <span class="material-symbols-outlined">check</span>
                        </a>
                        <div class="activity-content">
                          <span class="activity-time"><%= act.time %></span>
                          <span class="activity-text"><%= act.description %></span>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                </div>
          <% 
              }
          }); 
          %>
        </div>
      <% }); %>
    </main>

    <!-- Goals & Habits Footer Dashboard Card -->
    <% if (userData.goals && Array.isArray(userData.goals) && userData.goals.length > 0) { %>
      <footer class="goals-wrapper">
        <div class="goals-card">
          <div class="goals-header">
            <span class="material-symbols-outlined">explore</span>
            <h2 class="goals-title">Weekly Goals &amp; Habits</h2>
          </div>
          <div class="goals-list">
            <% userData.goals.forEach(function(goal) { %>
              <div class="goal-item">
                <span class="material-symbols-outlined">task_alt</span>
                <span class="goal-text"><%= goal %></span>
              </div>
            <% }); %>
          </div>
        </div>
      </footer>
    <% } %>

  </div>
</body>
</html>
